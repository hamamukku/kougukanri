# Unset/empty uses default behavior based on NOTIFY_WEBHOOK_URL.
NOTIFY_ENABLED=

ENABLE_SEED_ADMIN=false
SEED_ADMIN_DEPARTMENT=仮会社
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
