PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kougukanri?sslmode=disable&TimeZone=Asia%2FTokyo
MIGRATIONS_PATH=file://./db/migrations
JWT_SECRET=replace-this
JWT_EXPIRES_HOURS=24
CRON_ENABLED=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_WEBHOOK_URL=
